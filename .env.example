PORT=3000
NODE_ENV=production

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# Google's latest Gemma 4 (Apr 2026) — pick the size that fits your hardware:
#   gemma4:e2b  — ~7.2 GB, fastest on-device variant
#   gemma4:e4b  — ~9.6 GB, default — multimodal, 256K ctx, 140+ languages
#   gemma4:26b  — ~18 GB,  MoE — strong reasoning
#   gemma4:31b  — ~20 GB,  dense — top quality (#3 open model on Arena)
# Pull with:  ollama pull gemma4:e4b
OLLAMA_MODEL=gemma4:e4b
OLLAMA_TIMEOUT_MS=90000
OLLAMA_MAX_RETRIES=2
OLLAMA_RETRY_DELAY_MS=1000

# Generation tuning
OLLAMA_NUM_PREDICT=512
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.9
OLLAMA_REPEAT_PENALTY=1.1

# ── Circuit breaker ───────────────────────────────────────────────────────────
CB_FAILURE_THRESHOLD=5
CB_COOLDOWN_MS=30000

# ── Request queue (CPU=1, GPU can go higher) ──────────────────────────────────
QUEUE_CONCURRENCY=1
QUEUE_MAX_PENDING=10

# ── Rate limiting (per IP) ────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# ── Auth — leave blank to disable API key requirement ─────────────────────────
API_KEY=

# ── CORS — set to your frontend origin in production ─────────────────────────
CORS_ORIGIN=*

# ── Input ─────────────────────────────────────────────────────────────────────
MAX_MESSAGE_LENGTH=2000
